# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy this to .env and fill in real values.
# NEVER commit .env — only commit this file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# LOCAL:      postgresql://user:password@localhost:5432/aicalling
# RAILWAY:    (auto-provided by Railway Postgres add-on)
DATABASE_URL=postgresql://user:password@localhost:5432/aicalling
REDIS_URL=redis://localhost:6379

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000

# ── Twilio ────────────────────────────────────────────────────────────────────
TELEPHONY_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── AI Providers ──────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Public URL (ngrok locally / Railway URL in production) ────────────────────
# LOCAL:      https://xxxx-xxxx.ngrok-free.app
# PRODUCTION: https://your-service.railway.app
BASE_URL=https://your-ngrok-or-production-url.app

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Call limits ───────────────────────────────────────────────────────────────
MAX_CONCURRENT_CALLS=10
MAX_CALLS_PER_TENANT=5
MAX_CONFUSION_RETRIES=2

# ── Google Cloud ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
