# ── Secrets (NEVER commit these) ──────────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
**/env.json
**/*.pem
**/*.key
**/*.p12
**/*.pfx

# ── Node ──────────────────────────────────────────────────────────────────────
**/node_modules/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*

# ── Build outputs ─────────────────────────────────────────────────────────────
**/dist/
**/build/
**/.next/
**/.nuxt/
**/.output/

# ── Recordings & media (large binary files) ───────────────────────────────────
recordings/
**/*.wav
**/*.mp3
**/*.mp4
**/*.ogg

# ── Logs ──────────────────────────────────────────────────────────────────────
**/*.log
**/logs/

# ── OS & editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Test artifacts ────────────────────────────────────────────────────────────
**/coverage/
**/.nyc_output/

# ── Prisma (keep schema, ignore generated client) ─────────────────────────────
**/prisma/generated/
