DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Worker concurrency (tune based on Groq tier and DB capacity)
CONCURRENCY_NORMALIZE=50
CONCURRENCY_EXTRACT=10
CONCURRENCY_EVALUATE=100
CONCURRENCY_COMPLIANCE=100
CONCURRENCY_ASSEMBLE=50

PORT=4000
LOG_LEVEL=info
NODE_ENV=development

# Protects /admin/* API and /admin/queues BullMQ Board
ADMIN_API_KEY=change-me-in-production
