generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  members     WorkspaceMember[]
  campaigns   Campaign[]
  contacts    Contact[]
  callModules CallModule[]
  callLogs    CallLog[]
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  name         String
  passwordHash String
  role         Role       @default(VIEWER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())

  workspaces     WorkspaceMember[]
  refreshTokens  RefreshToken[]
  campaigns      Campaign[]
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  userId      String
  tenantId    String
  role        Role     @default(VIEWER)
  createdAt   DateTime @default(now())

  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CallModule {
  id              String     @id @default(uuid())
  name            String
  prompt          String?

  goal            String?
  callIntro       String?
  callSignOff     String?
  courtesyClose   Boolean   @default(false)

  successCriteria String?
  tenantId        String
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  campaigns       Campaign[]
}

model Campaign {
  id            String       @id @default(uuid())
  name          String
  type          CampaignType @default(HR)
  dataToCollect Json?
  endCallIf     String?
  rules         Json?
  callSettings  Json?

  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  callModuleId String
  callModule   CallModule @relation(fields: [callModuleId], references: [id])

  createdById  String?
  createdBy    User?      @relation(fields: [createdById], references: [id])

  campaignContacts CampaignContact[]
  callLogs         CallLog[]
  createdAt        DateTime          @default(now())
}

model Contact {
  id       String @id @default(uuid())
  name     String
  phone    String
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  campaignContacts CampaignContact[]
  callLogs         CallLog[]
}

model CampaignContact {
  id         String @id @default(uuid())
  campaignId String
  contactId  String
  overrides  Json?

  campaign Campaign @relation(fields: [campaignId], references: [id])
  contact  Contact  @relation(fields: [contactId], references: [id])
}

model CallLog {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  contactId    String
  contact      Contact   @relation(fields: [contactId], references: [id])
  campaignId   String?
  campaign     Campaign? @relation(fields: [campaignId], references: [id])
  status       String
  transcript   String?
  recordingUrl String?
  providerRef  String?
  durationMs   Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum CampaignType {
  HR
  RECRUITER
  SALES
  LOAN_RECOVERY
  FEEDBACK
}

// ==========================================
// EVALUATION SERVICE MODELS
// ==========================================

model CallReport {
  id             String   @id @default(uuid())
  callLogId      String   @unique
  campaignId     String?
  tenantId       String?
  contactName    String?

  outcome        String?  
  failureReason  String?  
  sentiment      String?  
  score          Int?     
  reportSummary  String?  
  completionRate Float?   

  extractedFields Json?   
  missingFields   Json?   
  complianceData  Json?   
  scoreBreakdown  Json?   
  reportData      Json?   

  schemaVersion  String   @default("1.0")
  modelVersion   String?  

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  job            ReportJob?

  @@index([campaignId, outcome])
  @@index([campaignId, score])
  @@index([campaignId, sentiment])
  @@index([campaignId, createdAt])
  @@index([tenantId, createdAt])
}

model ReportJob {
  id               String     @id @default(uuid())
  callLogId        String     @unique
  report           CallReport @relation(fields: [callLogId], references: [callLogId])

  ingestStatus     String     @default("pending")
  normalizeStatus  String     @default("pending")
  extractStatus    String     @default("pending")
  evaluateStatus   String     @default("pending")
  complianceStatus String     @default("pending")
  assembleStatus   String     @default("pending")

  totalAttempts    Int        @default(0)
  lastError        String?
  priority         Int        @default(1) 

  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([extractStatus])
  @@index([assembleStatus])
}

model DLQEntry {
  id         String   @id @default(uuid())
  callLogId  String
  stage      String
  payload    Json
  error      String
  stackTrace String?
  attempts   Int
  canRetry   Boolean  @default(true)
  retried    Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([callLogId])
  @@index([stage])
  @@index([retried])
}
